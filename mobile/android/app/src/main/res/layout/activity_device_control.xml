<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Device Header Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            style="@style/CardDark">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_device_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SC1240"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/tv_device_address"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AA:BB:CC:DD:EE:FF"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_connection_chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● TERHUBUNG"
                    android:textSize="12sp"
                    android:textColor="@color/green_ok"
                    android:background="@drawable/bg_chip"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Error Banner (hidden by default) -->
        <LinearLayout
            android:id="@+id/error_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/red_dark"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:layout_marginBottom="10dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠"
                android:textSize="18sp"
                android:textColor="@color/red_error"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tv_error_message"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Error detected"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/red_error" />
        </LinearLayout>

        <!-- Status Grid — 2x2 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STATUS REAL-TIME"
            android:textSize="11sp"
            android:textColor="@color/cyan_accent"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"
            android:paddingStart="4dp" />

        <!-- Row 1: Lock State + Vehicle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                style="@style/CardDark">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="POSISI PALANG"
                        android:textSize="10sp"
                        android:textColor="@color/text_secondary"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:id="@+id/tv_lock_state"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="\? MENUNGGU..."
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                style="@style/CardDark">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="KENDARAAN"
                        android:textSize="10sp"
                        android:textColor="@color/text_secondary"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:id="@+id/tv_vehicle_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="○ KOSONG"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/green_ok"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Row 2: Battery + Sensor -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                style="@style/CardDark">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="BATERAI"
                            android:textSize="10sp"
                            android:textColor="@color/text_secondary"
                            android:letterSpacing="0.08" />

                        <TextView
                            android:id="@+id/tv_solar_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="— Solar"
                            android:textSize="10sp"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:id="@+id/tv_battery_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—%"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/green_ok" />

                        <TextView
                            android:id="@+id/tv_battery_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NORMAL"
                            android:textSize="10sp"
                            android:textColor="@color/green_ok"
                            android:layout_marginStart="6dp" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progress_battery"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:progress="50"
                        android:max="100"
                        android:progressTint="@color/green_ok"
                        android:layout_marginTop="6dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:orientation="vertical">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    style="@style/CardDark">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SENSOR"
                            android:textSize="10sp"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/tv_sensor_mode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/cyan_accent"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/CardDark">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SUDUT BAFFLE"
                            android:textSize="10sp"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/tv_baffle_angle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—°"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </LinearLayout>

        <!-- Command Buttons -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KONTROL MANUAL"
            android:textSize="11sp"
            android:textColor="@color/cyan_accent"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"
            android:layout_marginTop="4dp"
            android:paddingStart="4dp" />

        <!-- RAISE — Green, full width, large -->
        <Button
            android:id="@+id/btn_raise"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="▲  ANGKAT PALANG (RAISE)"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"
            style="@style/ButtonRaise" />

        <!-- LOWER — Red, full width -->
        <Button
            android:id="@+id/btn_lower"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="▼  TURUNKAN PALANG (LOWER)"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"
            style="@style/ButtonLower" />

        <!-- Row: Reset + Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btn_reset"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="↺ RESET"
                android:layout_marginEnd="6dp"
                style="@style/ButtonSecondary" />

            <Button
                android:id="@+id/btn_status"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="\? STATUS"
                android:layout_marginStart="6dp"
                style="@style/ButtonSecondary" />
        </LinearLayout>

        <!-- Command Progress -->
        <LinearLayout
            android:id="@+id/command_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="10dp"
            android:background="@drawable/bg_card_dark"
            android:layout_marginBottom="10dp"
            android:visibility="gone">

            <ProgressBar
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:indeterminate="true"
                android:indeterminateTint="@color/cyan_accent"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/tv_command_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mengirim perintah…"
                android:textSize="13sp"
                android:textColor="@color/cyan_accent" />
        </LinearLayout>

        <!-- Live Log Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/CardDark">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LOG AKTIF"
                    android:textSize="10sp"
                    android:textColor="@color/cyan_accent"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_live_log"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Menunggu aktivitas…"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
