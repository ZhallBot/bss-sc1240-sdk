<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base Application Theme — Dark -->
    <style name="Theme.BSSParking" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/cyan_accent</item>
        <item name="colorPrimaryDark">@color/cyan_dark</item>
        <item name="colorAccent">@color/green_ok</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="actionBarStyle">@style/BSS.ActionBar</item>
        <item name="toolbarStyle">@style/BSS.Toolbar</item>
    </style>

    <!-- Theme with ActionBar (for activities that use it) -->
    <style name="Theme.BSSParking.ActionBar" parent="Theme.MaterialComponents.DayNight">
        <item name="colorPrimary">@color/bg_card</item>
        <item name="colorPrimaryDark">@color/bg_dark</item>
        <item name="colorAccent">@color/cyan_accent</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="actionBarStyle">@style/BSS.ActionBar</item>
    </style>

    <style name="BSS.ActionBar" parent="Widget.AppCompat.ActionBar">
        <item name="background">@color/bg_card</item>
        <item name="titleTextStyle">@style/BSS.ActionBar.Title</item>
        <item name="subtitleTextStyle">@style/BSS.ActionBar.Subtitle</item>
        <item name="elevation">4dp</item>
    </style>

    <style name="BSS.ActionBar.Title" parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">17sp</item>
    </style>

    <style name="BSS.ActionBar.Subtitle" parent="TextAppearance.AppCompat.Widget.ActionBar.Subtitle">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="BSS.Toolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@color/bg_card</item>
        <item name="titleTextColor">@color/text_primary</item>
    </style>

    <!-- Splash theme (no action bar) -->
    <style name="Theme.BSSParking.Splash" parent="Theme.BSSParking">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
    </style>

    <!-- Card style -->
    <style name="CardDark" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
        <item name="strokeColor">@color/bg_card_border</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Buttons -->
    <style name="ButtonPrimary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/cyan_accent</item>
        <item name="android:textColor">@color/bg_dark</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">10dp</item>
    </style>

    <style name="ButtonSecondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/bg_card_border</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="cornerRadius">10dp</item>
    </style>

    <style name="ButtonRaise" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/green_dark</item>
        <item name="android:textColor">@color/green_ok</item>
        <item name="android:textStyle">bold</item>
        <item name="strokeColor">@color/green_ok</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="ButtonLower" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/red_dark</item>
        <item name="android:textColor">@color/red_error</item>
        <item name="android:textStyle">bold</item>
        <item name="strokeColor">@color/red_error</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="cornerRadius">12dp</item>
    </style>

</resources>
